{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "after 10pm every weekday",
    "before 5am every weekday",
    "every weekend"
  ],
  "labels": [
    "dependencies"
  ],
  "rangeStrategy": "bump",
  "semanticCommits": "enabled",
  "semanticCommitType": "deps",
  "semanticCommitScope": null,
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "automerge": true,
    "automergeType": "pr"
  },
  "prConcurrentLimit": 20,
  "prCreation": "immediate",
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest", "major"],
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Bump the mise.toml rust pin and the Dockerfile rust image together so the toolchains never drift",
      "matchDepNames": ["rust"],
      "matchManagers": ["mise", "dockerfile"],
      "groupName": "rust toolchain"
    }
  ]
}
